<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostics Results"
        Width="760" Height="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#0F0F1A"
        Topmost="True">
    <Window.Resources>

        <!-- ── Rounded pill button ── -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Chrome icon button ── -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#8888AA"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A45"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stat card ── -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,14"/>
        </Style>

        <!-- ── Custom dark vertical scrollbar ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="8"/>
            <Setter Property="Background" Value="#0F0F1A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#16162A" CornerRadius="4" Width="8">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#4A4A7A" CornerRadius="4" Margin="1,3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer border: visible edge with WindowStyle=None -->
    <Border BorderBrush="#2A2A45" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════ HEADER ══════════════════════ -->
            <Border Name="HeaderBar"
                    Grid.Row="0"
                    Background="#16162A"
                    BorderBrush="#2A2A45" BorderThickness="0,0,0,1"
                    Padding="24,14,16,14"
                    Cursor="SizeAll">
                <StackPanel>

                    <!-- Top row: logo + title  |  action buttons  |  chrome -->
                    <DockPanel>

                        <!-- Chrome: minimize + close (far right) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Top" Margin="0,-2,0,0">
                            <Button Name="MinimizeButton"    Content="─"
                                    Style="{StaticResource ChromeButton}" Margin="0,0,2,0"/>
                            <Button Name="ChromeCloseButton" Content="✕"
                                    Style="{StaticResource ChromeButton}"/>
                        </StackPanel>

                        <!-- Action buttons (left of chrome) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,14,0">
                            <Button Name="FixAllButton" Content="⚡  Fix All"
                                    Style="{StaticResource PillButton}"
                                    Background="#C84B00" Margin="0,0,8,0"/>
                            <Button Name="CloseButton" Content="Close"
                                    Style="{StaticResource PillButton}"
                                    Background="#3A3A60"/>
                        </StackPanel>

                        <!-- Logo + title block -->
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Name="LogoImage" Height="28" MaxWidth="120"
                                       Margin="0,0,12,0" VerticalAlignment="Center"
                                       Stretch="Uniform" Visibility="Collapsed"/>
                                <TextBlock Name="HeaderTitle" Text="Diagnostics Results"
                                           Foreground="White" FontSize="22" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Name="TimestampText" Text="Completed at: …"
                                       Foreground="#6666AA" FontSize="11" Margin="0,4,0,0"/>
                            <TextBlock Name="FixAllStatus" Text="" Foreground="#AAAACC"
                                       FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                    </DockPanel>

                    <!-- ── Conclusion banner (below title/buttons, draws eye to action area) ── -->
                    <Border Name="ConclusionBanner"
                            CornerRadius="6" BorderThickness="1"
                            Padding="14,9" Margin="0,12,0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Name="ConclusionIcon" Text="" FontSize="14"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Name="ConclusionText" Text=""
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════════════════════ AUTO-CLOSE BAR ══════════════════════ -->
            <StackPanel Grid.Row="1" Background="#0F0F1A">
                <ProgressBar Name="TimeoutProgress" Height="2"
                             Foreground="#7C6AF7" Background="Transparent"/>
                <TextBlock Name="TimeoutText" Text="Auto-closing…"
                           FontSize="9" Foreground="#444466"
                           Margin="24,3,0,6"/>
            </StackPanel>

            <!-- ══════════════════════ STAT STRIP ══════════════════════ -->
            <Border Grid.Row="2" Padding="24,14,24,14" Background="#0F0F1A">
                <UniformGrid Rows="1" Columns="3">

                    <Border Style="{StaticResource StatCard}"
                            Background="#0D2218" BorderBrush="#1A5C35" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="PASSED" Foreground="#2E7D52"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Name="PassedCount" Text="0"
                                       Foreground="#4ADE80" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCard}"
                            Background="#1F0D0D" BorderBrush="#5C1A1A" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="FAILED" Foreground="#7D2E2E"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Name="FailedCount" Text="0"
                                       Foreground="#F87171" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCard}"
                            Background="#1F1808" BorderBrush="#5C4A1A">
                        <StackPanel>
                            <TextBlock Text="WARNINGS" Foreground="#7D622E"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Name="WarningCount" Text="0"
                                       Foreground="#FBBF24" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </Border>

            <!-- ══════════════════════ STEP CARDS ══════════════════════ -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          Background="#0F0F1A"
                          Padding="24,4,24,16">
                <StackPanel Name="ResultsPanel"/>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
