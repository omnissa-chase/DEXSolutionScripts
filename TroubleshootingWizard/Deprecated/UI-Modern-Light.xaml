<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostics Results"
        Width="760" Height="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#F3F4F8"
        Topmost="True">
    <Window.Resources>

        <!-- ── Rounded pill button ── -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Chrome icon button ── -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#8899BB"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDE2EE"/>
                                <Setter Property="Foreground" Value="#334477"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stat card ── -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,14"/>
        </Style>

        <!-- ── Light scrollbar ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="8"/>
            <Setter Property="Background" Value="#F3F4F8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#E8EAF0" CornerRadius="4" Width="8">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#B0B8D0" CornerRadius="4" Margin="1,3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Window edge -->
    <Border BorderBrush="#D0D5E8" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════ HEADER ══════════════════════ -->
            <Border Name="HeaderBar"
                    Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="#D0D5E8" BorderThickness="0,0,0,1"
                    Padding="24,14,16,14"
                    Cursor="SizeAll">
                <StackPanel>

                    <!-- Top row -->
                    <DockPanel>

                        <!-- Chrome buttons -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Top" Margin="0,-2,0,0">
                            <Button Name="MinimizeButton"    Content="─"
                                    Style="{StaticResource ChromeButton}" Margin="0,0,2,0"/>
                            <Button Name="ChromeCloseButton" Content="✕"
                                    Style="{StaticResource ChromeButton}"/>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,14,0">
                            <Button Name="FixAllButton" Content="⚡  Fix All"
                                    Style="{StaticResource PillButton}"
                                    Background="#D84300" Margin="0,0,8,0"/>
                            <Button Name="CloseButton" Content="Close"
                                    Style="{StaticResource PillButton}"
                                    Background="#5C6890"/>
                        </StackPanel>

                        <!-- Logo + title -->
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Name="LogoImage" Height="28" MaxWidth="120"
                                       Margin="0,0,12,0" VerticalAlignment="Center"
                                       Stretch="Uniform" Visibility="Collapsed"/>
                                <TextBlock Name="HeaderTitle" Text="Diagnostics Results"
                                           Foreground="#1A1F3C" FontSize="22" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Name="TimestampText" Text="Completed at: …"
                                       Foreground="#7788AA" FontSize="11" Margin="0,4,0,0"/>
                            <TextBlock Name="FixAllStatus" Text="" Foreground="#556688"
                                       FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                    </DockPanel>

                    <!-- Conclusion banner -->
                    <Border Name="ConclusionBanner"
                            CornerRadius="6" BorderThickness="1"
                            Padding="14,9" Margin="0,12,0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Name="ConclusionIcon" Text="" FontSize="14"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Name="ConclusionText" Text=""
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════════════════════ AUTO-CLOSE BAR ══════════════════════ -->
            <StackPanel Grid.Row="1" Background="#F3F4F8">
                <ProgressBar Name="TimeoutProgress" Height="2"
                             Foreground="#5C6FD4" Background="Transparent"/>
                <TextBlock Name="TimeoutText" Text="Auto-closing…"
                           FontSize="9" Foreground="#AABBCC"
                           Margin="24,3,0,6"/>
            </StackPanel>

            <!-- ══════════════════════ STAT STRIP ══════════════════════ -->
            <Border Grid.Row="2" Padding="24,14,24,14" Background="#F3F4F8">
                <UniformGrid Rows="1" Columns="3">

                    <Border Style="{StaticResource StatCard}"
                            Background="#F0FAF4" BorderBrush="#A8D8B8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="PASSED" Foreground="#3A8A5A"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Name="PassedCount" Text="0"
                                       Foreground="#1E6E42" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCard}"
                            Background="#FFF0F0" BorderBrush="#F0A8A8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="FAILED" Foreground="#C04040"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Name="FailedCount" Text="0"
                                       Foreground="#B02020" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCard}"
                            Background="#FFFBF0" BorderBrush="#F0D888">
                        <StackPanel>
                            <TextBlock Text="WARNINGS" Foreground="#A07020"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Name="WarningCount" Text="0"
                                       Foreground="#8A5C00" FontSize="30" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </Border>

            <!-- ══════════════════════ STEP CARDS ══════════════════════ -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          Background="#F3F4F8"
                          Padding="24,4,24,16">
                <StackPanel Name="ResultsPanel"/>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
